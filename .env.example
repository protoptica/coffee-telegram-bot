TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
OCR_SPACE_API_KEY=replace-with-your-ocr-space-key-or-helloworld

# Storage backend: json or supabase
STORAGE_BACKEND=supabase

# Local storage path for dev mode and temporary hosted files
TELEGRAM_STORAGE_DIR=./storage

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# Temporary backward-compatibility fallback only. Do not use for new setups.
# SUPABASE_ANON_KEY=
